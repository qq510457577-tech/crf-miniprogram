/* =============== CRF 数据采集平台 - 科技医疗风格 =============== */
/* 设计系统：Hi-Tech Medical - 深邃、科技、专业 */

page {
  /* ========== 科技医疗主色调 ========== */
  /* 深邃科技蓝 - 主品牌色 */
  --brand-1: #0088FF;
  --brand-2: #00BFFF;
  --brand-3: #4FC3F7;
  
  /* 科技渐变背景 */
  --brand-gradient: linear-gradient(135deg, #0A1628 0%, #1A2F4E 50%, #0D3D56 100%);
  --brand-gradient-light: linear-gradient(135deg, rgba(0, 136, 255, 0.15) 0%, rgba(0, 191, 255, 0.1) 100%);
  
  /* 霓虹强调色 - 科技感 */
  --neon-cyan: #00F5D4;
  --neon-blue: #4FACFE;
  --neon-purple: #7C3AED;
  
  /* 功能色 - 保持医疗感 */
  --success: #00E676;
  --warning: #FFB300;
  --danger: #FF5252;
  --info: #00B8D4;
  
  /* ========== 深色背景系统 ========== */
  --bg: #0A0E14;
  --bg-card: rgba(26, 31, 46, 0.85);
  --bg-glass: rgba(26, 31, 46, 0.6);
  --bg-elevated: rgba(35, 42, 62, 0.9);
  
  /* 文字色 - 高对比度 */
  --text-primary: #FFFFFF;
  --text-secondary: #A8B2C1;
  --text-tertiary: #6B7A8F;
  --text-placeholder: #4A5568;
  
  /* 边框 - 科技发光边框 */
  --border: rgba(0, 136, 255, 0.2);
  --border-light: rgba(255, 255, 255, 0.08);
  --border-glow: rgba(0, 245, 212, 0.3);
  --divider: rgba(255, 255, 255, 0.06);
  
  /* ========== 阴影系统 - 科技发光 ========== */
  --shadow-sm: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  --shadow-md: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.5);
  --shadow-glow: 0 0 30rpx rgba(0, 245, 212, 0.2);
  --shadow-brand: 0 8rpx 32rpx rgba(0, 136, 255, 0.3);
  
  /* ========== 圆角 ========== */
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  
  /* ========== 间距 ========== */
  --spacing-xs: 12rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 28rpx;
  --spacing-lg: 40rpx;
  --spacing-xl: 56rpx;
  
  /* ========== 字体 ========== */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 26rpx;
  --font-base: 28rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-2xl: 52rpx;
  --font-3xl: 72rpx;
  
  /* ========== 过渡 ========== */
  --transition-fast: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-normal: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-glow: all 0.3s ease;
  
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', Helvetica, Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background-color: var(--bg);
  color: var(--text-primary);
  font-size: var(--font-base);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* TDesign 深色主题覆盖 */
page {
  --td-brand-color: #0088FF;
  --td-brand-color-light: rgba(0, 136, 255, 0.15);
  --td-brand-color-focus: rgba(0, 191, 255, 0.2);
  --td-brand-color-disabled: rgba(0, 136, 255, 0.3);
  --td-brand-color-hover: #00BFFF;
  --td-brand-color-active: #0066CC;
  --td-error-color: #FF5252;
  --td-warning-color: #FFB300;
  --td-success-color: #00E676;
  --td-font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', Helvetica, Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* ========== 通用组件样式 ========== */

/* 玻璃态卡片 */
.card {
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

/* 通用页面容器 */
.page-container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 通用分区标题 */
.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  padding: var(--spacing-md) var(--spacing-md) var(--spacing-sm);
  letter-spacing: 0.5rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-more {
  font-size: var(--font-sm);
  color: var(--neon-cyan);
  font-weight: 500;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-xl) 0;
  color: var(--text-tertiary);
  font-size: var(--font-base);
}

/* ========== 操作类 ========== */
.text-link { color: var(--brand-1); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger { color: var(--danger); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }

/* ========== 动画 ========== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.fade-in {
  animation: fadeIn 0.4s ease forwards;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.slide-up {
  animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* 呼吸发光动画 */
@keyframes glowPulse {
  0%, 100% { box-shadow: 0 0 20rpx rgba(0, 245, 212, 0.2); }
  50% { box-shadow: 0 0 40rpx rgba(0, 245, 212, 0.4); }
}
.glow-pulse {
  animation: glowPulse 2s ease-in-out infinite;
}

/* 扫描线动画 */
@keyframes scanLine {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(100vh); }
}
.scan-line {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
  opacity: 0.3;
  animation: scanLine 8s linear infinite;
  pointer-events: none;
  z-index: 9999;
}

/* 骨架屏 */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
.skeleton {
  background: linear-gradient(90deg, rgba(255,255,255,0.03) 25%, rgba(255,255,255,0.08) 37%, rgba(255,255,255,0.03) 63%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease infinite;
  border-radius: var(--radius-sm);
}

/* 渐变边框效果 */
.border-glow {
  position: relative;
}
.border-glow::before {
  content: '';
  position: absolute;
  inset: -1rpx;
  border-radius: inherit;
  padding: 1rpx;
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-blue));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}
