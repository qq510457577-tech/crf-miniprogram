/* =============== 数据统计页 - 医疗数据仪表盘 =============== */

.page-container {
  min-height: 100vh;
  background: var(--bg);
}

.navbar-title {
  color: #ffffff !important;
  font-weight: 600 !important;
}

/* ====== 分组统计卡片（三色渐变） ====== */
.group-stats {
  display: flex;
  gap: var(--spacing-sm);
  padding: 0 var(--spacing-md);
}

.stat-card {
  flex: 1;
  padding: var(--spacing-lg) var(--spacing-sm);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  color: #ffffff;
  transition: var(--transition-fast);
  box-shadow: var(--shadow-sm);
}

.stat-card:active {
  transform: scale(0.95);
}

.stat-card-1 { background: linear-gradient(135deg, #0052D9, #366EF4); }
.stat-card-2 { background: linear-gradient(135deg, #ED7B2F, #F59E4C); }
.stat-card-3 { background: linear-gradient(135deg, #00A870, #34D399); }

.stat-card .stat-value {
  font-size: var(--font-3xl);
  font-weight: 700;
  line-height: 1.2;
}

.stat-card .stat-label {
  font-size: var(--font-sm);
  font-weight: 500;
  opacity: 0.9;
}

.stat-card .stat-icon {
  font-size: var(--font-xl);
  opacity: 0.8;
}

/* ====== 总览卡片 ====== */
.overview-card {
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: var(--shadow-sm);
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}

.overview-value {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--text-primary);
}

.overview-label {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.overview-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border);
}

/* ====== 肿瘤分布横向柱状图 ====== */
.distribution-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.distribution-item {
  margin-bottom: var(--spacing-md);
}

.distribution-item:last-child {
  margin-bottom: 0;
}

.distribution-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--spacing-xs);
}

.distribution-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.distribution-count {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.distribution-bar {
  height: 28rpx;
  background: var(--border-light);
  border-radius: 14rpx;
  overflow: hidden;
}

.distribution-fill {
  height: 100%;
  background: var(--brand-gradient);
  border-radius: 14rpx;
  transition: width 0.6s ease;
  min-width: 8rpx;
}

/* ====== 临床分期徽章 ====== */
.stage-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-sm);
  box-shadow: var(--shadow-sm);
}

.stage-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  background: #F8F9FB;
  border-radius: var(--radius-sm);
}

.stage-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: var(--font-sm);
  font-weight: 600;
}

.stage-I { background: #E8F5E9; color: #2E7D32; }
.stage-II { background: #E3F2FD; color: #1565C0; }
.stage-III { background: #FFF3E0; color: #E65100; }
.stage-IV { background: #FFF5F5; color: #C62828; }
.stage-unknown { background: #F5F5F5; color: #9E9E9E; }

.stage-count {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

/* ====== 导出区 ====== */
.export-section {
  margin: 0 var(--spacing-md) var(--spacing-xl);
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.export-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  transition: var(--transition-fast);
}

.export-item:active {
  opacity: 0.7;
}

.export-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.export-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

.export-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* ====== 底部间距 ====== */
.bottom-spacer {
  height: 60rpx;
}
