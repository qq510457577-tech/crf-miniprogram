/* =============== 数据统计页 - 科技医疗风格仪表盘 =============== */

.page-container {
  min-height: 100vh;
  background: var(--bg);
  position: relative;
}

/* 背景网格 */
.page-container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    linear-gradient(rgba(0, 136, 255, 0.03) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 136, 255, 0.03) 1rpx, transparent 1rpx);
  background-size: 60rpx 60rpx;
  pointer-events: none;
  z-index: 0;
}

.navbar-title {
  color: #ffffff !important;
  font-weight: 600 !important;
}

/* ====== 分组统计卡片（科技渐变） ====== */
.group-stats {
  display: flex;
  gap: var(--spacing-sm);
  padding: var(--spacing-md);
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  padding: var(--spacing-lg) var(--spacing-sm);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  color: #ffffff;
  transition: var(--transition-glow);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
  opacity: 0;
  transition: var(--transition-fast);
}

.stat-card:active::before {
  opacity: 1;
}

.stat-card:active {
  transform: scale(0.95);
}

.stat-card-1 { 
  background: linear-gradient(135deg, #0088FF, #00BFFF); 
  box-shadow: 0 8rpx 32rpx rgba(0, 136, 255, 0.4);
}
.stat-card-2 { 
  background: linear-gradient(135deg, #7C3AED, #A855F7); 
  box-shadow: 0 8rpx 32rpx rgba(124, 58, 237, 0.4);
}
.stat-card-3 { 
  background: linear-gradient(135deg, #00E676, #00F5D4); 
  box-shadow: 0 8rpx 32rpx rgba(0, 230, 118, 0.4);
}

.stat-card .stat-value {
  font-size: var(--font-3xl);
  font-weight: 700;
  line-height: 1.2;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.stat-card .stat-label {
  font-size: var(--font-sm);
  font-weight: 500;
  opacity: 0.9;
}

.stat-card .stat-icon {
  font-size: var(--font-xl);
  opacity: 0.8;
}

/* ====== 总览卡片 ====== */
.overview-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-md);
  position: relative;
  z-index: 1;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}

.overview-value {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--neon-cyan);
  text-shadow: 0 0 20rpx rgba(0, 245, 212, 0.3);
}

.overview-label {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.overview-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border);
}

/* ====== 分布卡片 ====== */
.distribution-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
  position: relative;
  z-index: 1;
}

.distribution-item {
  margin-bottom: var(--spacing-md);
}

.distribution-item:last-child {
  margin-bottom: 0;
}

.distribution-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--spacing-xs);
}

.distribution-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.distribution-count {
  font-size: var(--font-sm);
  color: var(--neon-cyan);
  font-weight: 600;
}

.distribution-bar {
  height: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 14rpx;
  overflow: hidden;
  border: 1rpx solid var(--border);
}

.distribution-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--brand-1), var(--neon-cyan));
  border-radius: 14rpx;
  transition: width 0.6s ease;
  min-width: 8rpx;
  box-shadow: 0 0 16rpx rgba(0, 245, 212, 0.3);
}

/* ====== 临床分期徽章 ====== */
.stage-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-lg);
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-sm);
  border: 1rpx solid var(--border);
  position: relative;
  z-index: 1;
}

.stage-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  background: rgba(255, 255, 255, 0.03);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--border);
}

.stage-badge {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: var(--font-sm);
  font-weight: 600;
}

.stage-I { background: rgba(0, 230, 118, 0.15); color: #00E676; border: 1rpx solid rgba(0, 230, 118, 0.3); }
.stage-II { background: rgba(0, 136, 255, 0.15); color: #00BFFF; border: 1rpx solid rgba(0, 136, 255, 0.3); }
.stage-III { background: rgba(124, 58, 237, 0.15); color: #A855F7; border: 1rpx solid rgba(124, 58, 237, 0.3); }
.stage-IV { background: rgba(255, 82, 82, 0.15); color: #FF5252; border: 1rpx solid rgba(255, 82, 82, 0.3); }
.stage-unknown { background: rgba(255, 255, 255, 0.05); color: var(--text-tertiary); border: 1rpx solid var(--border); }

.stage-count {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--text-primary);
}

/* ====== 导出区 ====== */
.export-section {
  margin: 0 var(--spacing-md) var(--spacing-xl);
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
  position: relative;
  z-index: 1;
}

.export-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  transition: var(--transition-fast);
}

.export-item:active {
  opacity: 0.7;
}

.export-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.export-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

.export-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* ====== 底部间距 ====== */
.bottom-spacer {
  height: 60rpx;
}
