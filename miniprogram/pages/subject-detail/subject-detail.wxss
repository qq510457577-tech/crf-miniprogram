/* =============== 受试者详情页 - 专业医疗档案风格 =============== */

.page-container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 导航栏 */
.t-class-navbar {
  background: var(--brand-gradient) !important;
}

.navbar-title {
  color: #ffffff !important;
  font-weight: 600 !important;
}

/* ====== 信息卡片 ====== */
.info-card {
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.subject-id {
  display: flex;
  flex-direction: column;
}

.subject-id .label {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.subject-id .value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* ====== 信息网格 ====== */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-md) var(--spacing-lg);
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.item-label {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
}

.item-value {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
}

/* ====== 退出信息 ====== */
.exit-info {
  margin-top: var(--spacing-md);
  padding: var(--spacing-md);
  background: #FFF5F5;
  border-radius: var(--radius-sm);
  border: 2rpx solid #FFE0E0;
}

.exit-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--danger);
  margin-bottom: var(--spacing-sm);
}

.exit-row {
  display: flex;
  gap: var(--spacing-sm);
  margin-bottom: 4rpx;
}

.exit-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  min-width: 120rpx;
}

.exit-value {
  font-size: var(--font-sm);
  color: var(--text-primary);
}

.exit-reason {
  color: var(--danger);
}

/* ====== 操作按钮 ====== */
.action-buttons {
  margin-top: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.action-buttons t-button .t-button {
  border-radius: var(--radius-sm) !important;
  height: 80rpx !important;
  font-size: var(--font-base) !important;
  font-weight: 500 !important;
}

/* ====== 记录区域 ====== */
.records-section {
  margin: 0 var(--spacing-md);
}

.record-list {
  margin-top: var(--spacing-sm);
  padding-bottom: 60rpx;
}

.record-item {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-sm);
  transition: var(--transition-fast);
  border: 2rpx solid transparent;
}

.record-item:active {
  border-color: var(--brand-1);
  transform: translateX(4rpx);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.record-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

.record-date {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.record-summary {
  font-size: var(--font-md);
  color: var(--text-secondary);
  line-height: 1.5;
}

.record-weight,
.record-score {
  font-size: var(--font-base);
  color: var(--brand-1);
  font-weight: 600;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: var(--spacing-md);
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-tertiary);
}

.add-btn-wrapper {
  margin-top: var(--spacing-md);
}

/* ====== 错误状态 ====== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: var(--spacing-lg);
}

.error-text {
  font-size: var(--font-base);
  color: var(--text-tertiary);
}

/* ====== TDesign Tabs 覆盖 ====== */
.records-section .t-tabs {
  --td-tab-item-color: var(--text-tertiary);
  --td-tab-item-active-color: var(--brand-1);
  --td-tab-track-color: var(--brand-1);
}
