/* =============== 首页 - 科技医疗风格仪表盘 =============== */

/* 扫描线装饰 */
.scan-line {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 245, 212, 0.6), transparent);
  animation: scanMove 4s linear infinite;
  pointer-events: none;
  z-index: 100;
}

@keyframes scanMove {
  0% { transform: translateY(-10rpx); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(100vh); opacity: 0; }
}

.page {
  min-height: 100vh;
  background: var(--bg);
  position: relative;
  overflow-x: hidden;
}

/* 背景网格装饰 */
.page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    linear-gradient(rgba(0, 136, 255, 0.03) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 136, 255, 0.03) 1rpx, transparent 1rpx);
  background-size: 60rpx 60rpx;
  pointer-events: none;
  z-index: 0;
}

/* ====== 头部 ====== */
.header {
  background: var(--brand-gradient);
  padding: var(--spacing-lg);
  padding-top: calc(var(--spacing-lg) + env(safe-area-inset-top));
  position: relative;
  overflow: hidden;
}

/* 头部光效装饰 */
.header::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(ellipse at 30% 30%, rgba(0, 245, 212, 0.15) 0%, transparent 50%),
              radial-gradient(ellipse at 70% 70%, rgba(0, 136, 255, 0.1) 0%, transparent 50%);
  animation: headerGlow 8s ease-in-out infinite alternate;
}

@keyframes headerGlow {
  0% { opacity: 0.6; transform: scale(1); }
  100% { opacity: 1; transform: scale(1.1); }
}

/* 头部波浪装饰 */
.header::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 60rpx;
  background: var(--bg);
  border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  z-index: 1;
}

.welcome-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 2;
}

.welcome-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.welcome-sub {
  display: block;
  font-size: var(--font-md);
  color: rgba(255, 255, 255, 0.6);
  font-weight: 400;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

/* ====== 快捷入口面板 ====== */
.quick-access {
  margin: -40rpx var(--spacing-md) var(--spacing-md);
  background: var(--bg-card);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  position: relative;
  z-index: 3;
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-lg);
}

.quick-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-lg);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.quick-title::before {
  content: '';
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--neon-cyan), var(--neon-blue));
  border-radius: 3rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-sm);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-md) var(--spacing-xs);
  border-radius: var(--radius-md);
  transition: var(--transition-glow);
  position: relative;
}

.quick-item::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(135deg, rgba(0, 245, 212, 0.1), rgba(0, 136, 255, 0.05));
  opacity: 0;
  transition: var(--transition-fast);
}

.quick-item:active::before {
  opacity: 1;
}

.quick-item:active {
  transform: scale(0.95);
}

.quick-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition-glow);
  position: relative;
  z-index: 1;
  box-shadow: var(--shadow-sm);
}

.quick-item:active .quick-icon {
  box-shadow: var(--shadow-glow);
}

.quick-label {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.quick-count {
  font-size: var(--font-xs);
  color: var(--neon-cyan);
  font-weight: 600;
}

/* ====== 分组统计 ====== */
.stats-section {
  margin: 0 var(--spacing-md) var(--spacing-md);
}

.stats-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-sm);
}

.stat-card {
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
  border: 1rpx solid var(--border);
  transition: var(--transition-glow);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, var(--neon-cyan), var(--neon-blue));
  opacity: 0;
  transition: var(--transition-fast);
}

.stat-card:active::before {
  opacity: 1;
}

.stat-card:active {
  transform: scale(0.96);
  border-color: var(--border-glow);
  box-shadow: var(--shadow-glow);
}

.stat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

.stat-value {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--neon-cyan);
  line-height: 1;
  text-shadow: 0 0 20rpx rgba(0, 245, 212, 0.3);
}

/* ====== 最新受试者 ====== */
.recent-section {
  margin: 0 var(--spacing-md) 140rpx;
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  border: 1rpx solid var(--border);
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--divider);
  transition: var(--transition-fast);
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-item:active {
  background: rgba(0, 245, 212, 0.05);
  margin: 0 calc(var(--spacing-md) * -1);
  padding-left: var(--spacing-md);
  padding-right: var(--spacing-md);
  border-radius: var(--radius-sm);
  border-bottom-color: transparent;
}

.recent-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.recent-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--brand-1), var(--brand-2));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  box-shadow: 0 0 20rpx rgba(0, 136, 255, 0.3);
}

.recent-name {
  display: block;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.recent-meta {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}
