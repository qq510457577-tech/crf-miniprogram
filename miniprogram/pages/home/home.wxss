.page { min-height: 100vh; background: #F5F5F5; }
.header { background: linear-gradient(135deg, #0052D9, #4364E7); padding: 32rpx; border-radius: 0 0 40rpx 40rpx; }
.welcome-row { display: flex; align-items: center; justify-content: space-between; }
.welcome-title { display: block; font-size: 36rpx; font-weight: 600; color: #fff; margin-bottom: 8rpx; }
.welcome-sub { display: block; font-size: 26rpx; color: rgba(255,255,255,0.7); }
.quick-access { background: #fff; margin: -48rpx 24rpx 24rpx; border-radius: 24rpx; padding: 32rpx; position: relative; z-index: 1; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.quick-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 28rpx; }
.quick-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24rpx; }
.quick-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.quick-icon { width: 96rpx; height: 96rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; }
.quick-label { font-size: 24rpx; color: #333; font-weight: 500; }
.quick-count { font-size: 20rpx; color: #999; }
.stats-section { margin: 0 24rpx 24rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.stats-list { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20rpx; }
.stat-card { background: #fff; border-radius: 20rpx; padding: 24rpx 20rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.stat-icon { width: 72rpx; height: 72rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; }
.stat-name { font-size: 22rpx; color: #666; }
.stat-value { font-size: 32rpx; font-weight: 700; color: #333; }
.recent-section { background: #fff; margin: 0 24rpx 120rpx; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.section-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.section-more { font-size: 26rpx; color: #0052D9; }
.empty-tip { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 48rpx 0; color: #CCC; font-size: 28rpx; }
.recent-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.recent-item:last-child { border-bottom: none; }
.recent-left { display: flex; align-items: center; gap: 20rpx; }
.recent-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: #F5F5F5; display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.recent-name { display: block; font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 6rpx; }
.recent-meta { display: block; font-size: 24rpx; color: #999; }
