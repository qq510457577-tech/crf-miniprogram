/* 个人中心页面样式 */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 用户信息卡片 */
.user-card {
  margin: 24rpx 32rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #0052d9 0%, #4378ff 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  color: #fff;
}

.avatar-wrapper {
  position: relative;
  margin-right: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #fff;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.role-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #0052d9;
  font-size: 20rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-dept {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #666;
}

/* 设置区域 */
.settings-section {
  margin: 0 32rpx 24rpx;
}

.settings-section t-cell-group {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.settings-section t-cell-group .t-cell-group__title {
  padding: 24rpx 32rpx 12rpx;
  font-size: 26rpx;
  color: #999;
}

/* 底部信息 */
.footer-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  opacity: 0.6;
}

.footer-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.footer-version {
  font-size: 24rpx;
  color: #999;
}

/* TDesign Override */
.navbar-title {
  color: #fff !important;
}

.t-cell--bordered {
  border: none !important;
}
