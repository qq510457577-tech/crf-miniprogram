/* =============== 记录表单页 - 清爽录入体验 =============== */

.page-container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

.navbar-title {
  color: #ffffff !important;
  font-weight: 600 !important;
}

/* ====== 受试者提示条 ====== */
.subject-tip {
  margin: var(--spacing-md);
  padding: var(--spacing-md);
  background: var(--brand-gradient);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-brand);
}

.tip-text {
  color: #ffffff;
  font-size: var(--font-base);
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* ====== 表单区块 ====== */
.form-section {
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

/* 每组表单项加一个分隔 */
.form-section .form-item:not(:last-child) {
  padding-bottom: var(--spacing-lg);
  border-bottom: 2rpx solid var(--border-light);
  margin-bottom: var(--spacing-lg);
}

/* ====== 表单项 ====== */
.form-item {
  margin-bottom: var(--spacing-lg);
}

.form-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: var(--font-base);
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
  font-weight: 600;
}

.form-label.required::after {
  content: ' *';
  color: var(--danger);
}

.form-hint {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-top: var(--spacing-xs);
  padding: var(--spacing-xs) var(--spacing-sm);
  background: #F8F9FB;
  border-radius: 8rpx;
}

/* ====== 输入框、选择器等背景覆盖 ====== */
.form-section t-input,
.form-section t-textarea {
  --td-input-bg-color: #F5F7FA;
  --td-textarea-bg-color: #F5F7FA;
}

.form-section t-input .t-input {
  background: #F5F7FA !important;
  border-radius: var(--radius-sm) !important;
  padding: 20rpx 24rpx !important;
  border: 2rpx solid transparent !important;
  transition: var(--transition-fast) !important;
}

.form-section t-input .t-input:focus,
.form-section t-input .t-input.t-input--focused {
  border-color: var(--brand-1) !important;
  background: #ffffff !important;
  box-shadow: 0 0 0 4rpx rgba(0, 82, 217, 0.1) !important;
}

t-textarea {
  background: #F5F7FA !important;
  border-radius: var(--radius-sm) !important;
  padding: var(--spacing-sm) !important;
  border: 2rpx solid transparent !important;
  transition: var(--transition-fast) !important;
}

t-textarea:focus-within {
  border-color: var(--brand-1) !important;
  background: #ffffff !important;
  box-shadow: 0 0 0 4rpx rgba(0, 82, 217, 0.1) !important;
}

t-stepper {
  background: #F5F7FA !important;
  border-radius: var(--radius-sm) !important;
  padding: 12rpx var(--spacing-sm) !important;
}

/* Radio 间距 */
t-radio {
  margin-bottom: var(--spacing-xs);
}

/* ====== PG-SGA 分数展示 ====== */
.result-item {
  background: var(--brand-gradient-light);
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  margin-top: var(--spacing-lg);
  border: 2rpx solid rgba(0, 82, 217, 0.1);
}

.score-display {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-sm);
}

.score-value {
  font-size: var(--font-3xl);
  font-weight: 700;
  color: var(--brand-1);
  line-height: 1;
}

.score-level {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: 500;
}

/* ====== 底部固定操作栏 ====== */
.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.form-actions t-button .t-button {
  border-radius: var(--radius-md) !important;
  height: 88rpx !important;
  font-size: var(--font-lg) !important;
  font-weight: 600 !important;
}
