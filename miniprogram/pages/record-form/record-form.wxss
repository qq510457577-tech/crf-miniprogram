/* 记录表单页面样式 */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

/* 受试者提示 */
.subject-tip {
  margin: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #0052d9 0%, #4378ff 100%);
  border-radius: 12rpx;
}

.tip-text {
  color: #fff;
  font-size: 28rpx;
}

/* 表单区块 */
.form-section {
  margin: 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-label.required::after {
  content: ' *';
  color: #e34d4d;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* picker值显示 */
.picker-value {
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

/* radio 样式 */
t-radio,
t-radio-group {
  display: block;
}

/* PG-SGA 分数展示 */
.result-item {
  background: #f0f5ff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-top: 32rpx;
}

.score-display {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.score-value {
  font-size: 64rpx;
  font-weight: bold;
  color: #0052d9;
}

.score-level {
  font-size: 28rpx;
  color: #666;
}

/* 表单操作区域 */
.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 滑块样式覆盖 */
t-slider .t-slider__value,
t-slider .t-slider__bar {
  font-size: 28rpx;
}

/* 输入框样式覆盖 */
.form-section t-input {
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* textarea 样式覆盖 */
t-textarea {
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
}

/* 步进器样式 */
t-stepper {
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
}

/* TDesign Override */
.navbar-title {
  color: #fff !important;
}
