.page { min-height: 100vh; background: #F5F5F5; padding-bottom: 120rpx; }
.nav-bar { background: #0052D9; }
.search-section { background: #fff; padding: 16rpx 24rpx 24rpx; border-radius: 0 0 32rpx 32rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); }
.filter-row { display: flex; align-items: center; justify-content: space-between; margin-top: 16rpx; }
.total-count { font-size: 26rpx; color: #666; }
.subject-list { height: calc(100vh - 220rpx); padding: 24rpx; }
.empty-wrap { display: flex; flex-direction: column; align-items: center; gap: 32rpx; padding: 120rpx 0; }
.subject-card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.card-header { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.card-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: #F0F5FF; display: flex; align-items: center; justify-content: center; font-size: 36rpx; flex-shrink: 0; }
.card-title-row { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; }
.card-title { font-size: 32rpx; font-weight: 600; color: #333; }
.card-info { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; margin-bottom: 20rpx; }
.info-row { display: flex; align-items: center; gap: 12rpx; }
.info-label { font-size: 24rpx; color: #999; min-width: 80rpx; }
.info-value { font-size: 26rpx; color: #333; font-weight: 500; }
.card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 20rpx; border-top: 1rpx solid #F0F0F0; }
.footer-text { font-size: 24rpx; color: #999; }
.load-more { text-align: center; padding: 32rpx; color: #0052D9; font-size: 28rpx; }
.no-more { text-align: center; padding: 32rpx; color: #CCC; font-size: 24rpx; }
.fab { position: fixed; right: 40rpx; bottom: 120rpx; width: 100rpx; height: 100rpx; border-radius: 50%; background: linear-gradient(135deg, #0052D9, #4364E7); display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(0,82,217,0.4); z-index: 100; }
